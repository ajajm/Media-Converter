# Docker Compose Configuration

# Backend Configuration
BACKEND_PORT=5000

# Frontend Configuration
FRONTEND_PORT=80

# API URL for frontend (used during build)
# For local development with Docker: http://localhost:5000
# For production: https://api.your-domain.com
VITE_API_URL=http://localhost:5000

# CORS Configuration
# For development: *
# For production: https://your-frontend-domain.com
CORS_ORIGIN=*
